# Pipeline E environment variables
# Copy to .env and fill in real values — never commit .env

# ----------------------------------------------------------
# OpenRouter API (used by S1 — VLM Page Intelligence)
# Create a Modal Secret named "openrouter-secret" containing
# this key so it's available inside Modal containers.
# ----------------------------------------------------------
OPENROUTER_API_KEY=sk-or-...

# ----------------------------------------------------------
# Modal (one-time setup — run `modal setup` instead)
# ----------------------------------------------------------
# MODAL_TOKEN_ID=...
# MODAL_TOKEN_SECRET=...

# ----------------------------------------------------------
# Cloudflare R2 object storage (optional — pipeline uses
# Modal Volumes by default; add R2 if you want external egress)
# ----------------------------------------------------------
# R2_ACCOUNT_ID=...
# R2_ACCESS_KEY_ID=...
# R2_SECRET_ACCESS_KEY=...
# R2_BUCKET_NAME=pipeline-e-artifacts

# ----------------------------------------------------------
# Neon PostgreSQL (optional — for job queue / results DB)
# ----------------------------------------------------------
# DATABASE_URL=postgresql://user:pass@host/db?sslmode=require
